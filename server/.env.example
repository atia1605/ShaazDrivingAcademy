# PostgreSQL — local: use docker compose (see repo root docker-compose.yml)
# Production: Neon, Supabase, Render Postgres, etc.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shaaz"

PORT=4000
# Comma-separated if you have several frontends
CLIENT_ORIGIN="http://localhost:5173,https://www.shaazdriving.com"
PUBLIC_APP_URL="http://localhost:5173"

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Optional: email notifications (Resend)
RESEND_API_KEY=
RESEND_FROM="Shaaz <noreply@yourdomain.com>"
SITE_OWNER_EMAIL="you@yourdomain.com"
