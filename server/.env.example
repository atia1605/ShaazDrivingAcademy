# MongoDB — local: docker compose (see repo root docker-compose.yml)
# Production: MongoDB Atlas — MUST include /databaseName before ? (Prisma P1013 if missing)
#   Good:  ...mongodb.net/shaaz?retryWrites=true&w=majority
#   Bad:   ...mongodb.net/?retryWrites=true&w=majority
# Local single-node:
DATABASE_URL="mongodb://root:example@localhost:27017/shaaz?authSource=admin&directConnection=true"

PORT=4000
CLIENT_ORIGIN="http://localhost:5173,https://www.shaazdriving.com"
PUBLIC_APP_URL="http://localhost:5173"

STRIPE_SECRET_KEY=

# Resend — https://resend.com — emails you when someone uses Contact or Register
# Never commit a real API key; paste it in Render and in local server/.env only.
RESEND_API_KEY=
# RESEND_FROM must use the SAME domain Resend shows as Verified (often send.yourdomain.com, not the root domain).
# Examples — pick the one that matches your Resend dashboard:
#   RESEND_FROM="Shaaz Driving <noreply@send.shaazdriving.com>"
#   RESEND_FROM="Shaaz Driving <noreply@shaazdriving.com>"
# Testing without DNS: RESEND_FROM="Shaaz <onboarding@resend.dev>"
RESEND_FROM="Shaaz Driving <noreply@shaazdriving.com>"
# Comma-separated = multiple recipients (one pair of quotes only — no "" inside).
SITE_OWNER_EMAIL="shohanchowdhury@hotmail.com,nahiabaksh21@gmail.com"

# Contact info in the automated “thank you” email to people who register (optional — has API defaults)
PUBLIC_CONTACT_EMAIL="shohanchowdhury@hotmail.com"
PUBLIC_CONTACT_PHONE="647-783-7582"

# Twilio SMS (optional) — if set, registration submissions are also sent as text message
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE="+10000000000"
SITE_OWNER_PHONE="+10000000000"
