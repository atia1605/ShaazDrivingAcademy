DATABASE_URL="file:./dev.db"
PORT=4000
# Comma-separated if you have several frontends (local + production)
CLIENT_ORIGIN="http://localhost:5173"
# Used for Stripe success/cancel URLs — must match the site users see (no trailing slash)
PUBLIC_APP_URL="http://localhost:5173"

# Stripe — https://dashboard.stripe.com/apikeys (test keys for development)
STRIPE_SECRET_KEY=

# Optional: email notifications when someone uses contact or registration forms
# https://resend.com — verify a domain and set RESEND_FROM to an address on that domain
RESEND_API_KEY=
RESEND_FROM="Shaaz <noreply@yourdomain.com>"
SITE_OWNER_EMAIL="you@yourdomain.com"
