# MongoDB — local: docker compose (see repo root docker-compose.yml)
# Production: MongoDB Atlas (https://www.mongodb.com/cloud/atlas) — copy SRV connection string
# Local single-node: add ?directConnection=true if Prisma warns about replica sets
DATABASE_URL="mongodb://root:example@localhost:27017/shaaz?authSource=admin&directConnection=true"

PORT=4000
CLIENT_ORIGIN="http://localhost:5173,https://www.shaazdriving.com"
PUBLIC_APP_URL="http://localhost:5173"

STRIPE_SECRET_KEY=

RESEND_API_KEY=
RESEND_FROM="Shaaz <noreply@yourdomain.com>"
SITE_OWNER_EMAIL="you@yourdomain.com"
